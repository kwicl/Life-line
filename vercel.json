{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    { "source": "/api/config", "destination": "/api/config" },
    { "source": "/api/milestones", "destination": "/api/milestones" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
